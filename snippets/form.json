{
  "procedure": {
    "prefix": "#procedure",
    "body": [
      "#procedure ${1:Name}(${2:args})",
      "\t$0",
      "#endprocedure"
    ],
    "description": "Define a #procedure / #endprocedure block"
  },

  "module": {
    "prefix": ".sort",
    "body": [
      ".sort: ${1:label}",
      "$0"
    ],
    "description": "Module boundary (.sort)"
  },

  "if": {
    "prefix": "if",
    "body": [
      "if ( ${1:condition} );",
      "\t$0",
      "endif;"
    ],
    "description": "if / endif block"
  },

  "if-else": {
    "prefix": "ifelse",
    "body": [
      "if ( ${1:condition} );",
      "\t$2",
      "else;",
      "\t$0",
      "endif;"
    ],
    "description": "if / else / endif block"
  },

  "repeat": {
    "prefix": "repeat",
    "body": [
      "repeat;",
      "\t$0",
      "endrepeat;"
    ],
    "description": "repeat / endrepeat block"
  },

  "argument": {
    "prefix": "argument",
    "body": [
      "argument ${1:FunctionName};",
      "\t$0",
      "endargument;"
    ],
    "description": "argument / endargument block"
  },

  "inside": {
    "prefix": "inside",
    "body": [
      "inside ${1:expr};",
      "\t$0",
      "endinside;"
    ],
    "description": "inside / endinside block"
  },

  "do-loop": {
    "prefix": "do",
    "body": [
      "do $${1:i} = ${2:1}, ${3:N};",
      "\t$0",
      "enddo;"
    ],
    "description": "do / enddo loop over a dollar variable"
  },

  "local": {
    "prefix": "Local",
    "body": [
      "Local ${1:Name} = ${0:expression};"
    ],
    "description": "Local expression definition"
  },

  "global": {
    "prefix": "Global",
    "body": [
      "Global ${1:Name} = ${0:expression};"
    ],
    "description": "Global expression definition"
  },

  "id": {
    "prefix": "id",
    "body": [
      "id ${1:lhs} = ${0:rhs};"
    ],
    "description": "Identity / substitution rule"
  },

  "symbol": {
    "prefix": "Symbol",
    "body": [
      "Symbol ${0:name};"
    ],
    "description": "Declare a symbol"
  },

  "symbols": {
    "prefix": "Symbols",
    "body": [
      "Symbols ${0:a, b, c};"
    ],
    "description": "Declare multiple symbols"
  },

  "function": {
    "prefix": "Function",
    "body": [
      "Function ${0:name};"
    ],
    "description": "Declare a function"
  },

  "vector": {
    "prefix": "Vector",
    "body": [
      "Vector ${0:p};"
    ],
    "description": "Declare a vector"
  },

  "index": {
    "prefix": "Index",
    "body": [
      "Index ${0:mu};"
    ],
    "description": "Declare an index"
  },

  "call": {
    "prefix": "#call",
    "body": [
      "#call ${1:ProcedureName}(${0:args})"
    ],
    "description": "#call a procedure"
  },

  "include": {
    "prefix": "#include",
    "body": [
      "#include ${0:file.frm}"
    ],
    "description": "#include a file"
  },

  "define": {
    "prefix": "#define",
    "body": [
      "#define ${1:NAME} \"${0:value}\""
    ],
    "description": "#define a preprocessor variable"
  },

  "ifdef": {
    "prefix": "#ifdef",
    "body": [
      "#ifdef `${1:NAME}'",
      "$0",
      "#endif"
    ],
    "description": "#ifdef / #endif preprocessor conditional"
  },

  "switch": {
    "prefix": "switch",
    "body": [
      "switch ( $${1:var} );",
      "  case ${2:val};",
      "    $0",
      "  default;",
      "endswitch;"
    ],
    "description": "switch / endswitch block"
  }
}
